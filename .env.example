# ─────────────────────────────────────────────────────────────
# PixVault Environment Variables
# Copy this file to .env.local and fill in your values.
# ALL services below are 100% FREE — no credit card needed.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PixVault
NODE_ENV=development

# ── Database — FREE FOREVER (no credit card) ─────────────────
# Option 1: Neon.tech (recommended)
# Sign up → https://neon.tech → Create project → copy connection string
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/pixvault?sslmode=require"

# Option 2: Supabase → https://supabase.com
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Option 3: Local Docker (run: docker-compose up -d db)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pixvault_dev"

# ── NextAuth.js ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-secret-key-minimum-32-characters-long

# ── OAuth (optional — email/password works without these) ─────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary — FREE FOREVER (no credit card) ────────────────
# 25 GB storage + 25 GB bandwidth/month FREE
# Sign up → https://cloudinary.com/users/register/free
# Dashboard → copy Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Hugging Face — FREE AI tagging (no credit card) ──────────
# 30,000 requests/month FREE
# Sign up → https://huggingface.co/join → Settings → Access Tokens → New Token (read)
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Image moderation (NSFW.js) ────────────────────────────────
# No config needed! NSFW.js runs locally using TensorFlow.js.
# It downloads the model automatically on first use (~50 MB).

# ── Duplicate detection (pHash via Sharp) ────────────────────
# No config needed! Runs locally using Sharp (already installed).
