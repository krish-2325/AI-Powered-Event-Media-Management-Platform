{
  "name": "PixVault",
  "short_name": "PixVault",
  "description": "Event & Media Management Platform for clubs and organizations",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#08080f",
  "theme_color": "#4f63ff",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["photo", "social", "productivity"],
